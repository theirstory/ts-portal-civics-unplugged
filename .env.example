WEAVIATE_HOST_URL=weaviate
WEAVIATE_PORT=8080
WEAVIATE_GRPC_HOST_URL=weaviate
WEAVIATE_GRPC_PORT=50051
WEAVIATE_SECURE=false

# LLM provider API keys (only the one matching your config.json provider is needed)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=

# For "openai-compatible" provider (Ollama, vLLM, Together, Groq, etc.)
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=

# Auth (optional — only needed if features.auth.enabled is true in config.json)
SITE_PASSWORD=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
